while True:
    number = int(input("Please type in a number: "))
    number2 = number
    if number <= 0:
        print("Thanks and bye!")
        break
    def factorial(number2):
        num = 1
        while number2 >= 1:
            num = num * number2
            number2 = number2 - 1
        return num
    f = factorial(number2)
    print(f"The factorial of the number {number} is {f}")
